HY3D_API_PORT=8000
HY3D_SERVER_WORKSPACE_ROOT=/app/server_workspace
HY3D_SERVER_EXPORTS_ROOT=/app/server_exports
HY3D_MODEL_CACHE=/app/model_cache
HY3D_JOB_TIMEOUT_SECONDS=900
HY3D_MAX_UPLOAD_MB=25

# Modo fixture/dev: permite validar la API sin TripoSR real.
HY3D_SERVER_FIXTURE_RESULT_PACKAGE=hy3d_v2/test_assets/result_package_sample.zip

# Modo motor real:
# HY3D_ENGINE_ROOT=/opt/triposr-local
# HY3D_WRAPPER_RUN=/app/tools/triposr/run_triposr_local.ps1

